class Solution {
    public String addStrings(String num1, String num2) {
        StringBuilder result = new StringBuilder();
        
        int i = num1.length() - 1;
        int j = num2.length() - 1;
        int carry = 0;
        
        // Loop as long as there are digits to add or a carry remaining
        while (i >= 0 || j >= 0 || carry > 0) {
            int sum = carry;
            
            // Add digit from num1 if available
            if (i >= 0) {
                sum += num1.charAt(i) - '0'; // Convert char to int
                i--;
            }
            
            // Add digit from num2 if available
            if (j >= 0) {
                sum += num2.charAt(j) - '0'; // Convert char to int
                j--;
            }
            
            // Calculate new carry and the digit to append
            carry = sum / 10;
            result.append(sum % 10);
        }
        
        // The digits were added from right to left, so reverse the result
        return result.reverse().toString();
    }
}
