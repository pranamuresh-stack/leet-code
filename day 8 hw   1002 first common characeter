import java.util.ArrayList;
import java.util.List;

class Solution {
    public List<String> commonChars(String[] words) {
        // Array to store the minimum frequency of each character across all words
        int[] minCounts = new int[26];
        
        // Initialize the array with the character counts of the first word
        for (char c : words[0].toCharArray()) {
            minCounts[c - 'a']++;
        }
        
        // Update the counts based on the remaining words
        for (int i = 1; i < words.length; i++) {
            int[] currentCounts = new int[26];
            for (char c : words[i].toCharArray()) {
                currentCounts[c - 'a']++;
            }
            
            // Keep the minimum frequency for each character
            for (int j = 0; j < 26; j++) {
                minCounts[j] = Math.min(minCounts[j], currentCounts[j]);
            }
        }
        
        // Collect the final list of common characters
        List<String> result = new ArrayList<>();
        for (int i = 0; i < 26; i++) {
            while (minCounts[i] > 0) {
                result.add(String.valueOf((char) (i + 'a')));
                minCounts[i]--;
            }
        }
        
        return result;
    }
}
