class Solution {
    public String mergeAlternately(String word1, String word2) {
        StringBuilder result = new StringBuilder();
        int i = 0;
        
        // Loop until we run out of characters in both strings
        while (i < word1.length() || i < word2.length()) {
            // Append from word1 if characters are still available
            if (i < word1.length()) {
                result.append(word1.charAt(i));
            }
            // Append from word2 if characters are still available
            if (i < word2.length()) {
                result.append(word2.charAt(i));
            }
            i++;
        }
        
        return result.toString();
    }
}
