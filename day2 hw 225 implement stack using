import java.util.LinkedList;
import java.util.Queue;

class MyStack {
    private Queue<Integer> queue;

    public MyStack() {
        queue = new LinkedList<>();
    }
    
    // Push element x onto stack.
    // Time Complexity: O(n) - We rotate the queue to bring the new element to the front
    public void push(int x) {
        queue.add(x);
        int size = queue.size();
        // Rotate the queue to place the newly added element at the front
        for (int i = 0; i < size - 1; i++) {
            queue.add(queue.remove());
        }
    }
    
    // Removes the element on top of the stack and returns it.
    // Time Complexity: O(1)
    public int pop() {
        return queue.remove();
    }
    
    // Get the top element.
    // Time Complexity: O(1)
    public int top() {
        return queue.peek();
    }
    
    // Returns whether the stack is empty.
    // Time Complexity: O(1)
    public boolean empty() {
        return queue.isEmpty();
    }
}
